# Vela Environment Configuration
# Copy this file to .env and fill in your values

# === Cesium Ion ===
# Register at https://cesium.com/ion/ for free
# If missing, globe falls back to open-source imagery with console warning
VITE_CESIUM_ION_TOKEN=

# === Space-Track.org (Phase 2+) ===
# Register at https://www.space-track.org/auth/createAccount
SPACETRACK_USERNAME=
SPACETRACK_PASSWORD=

# === Backend ===
API_HOST=0.0.0.0
API_PORT=8000

# === Data Paths ===
# UCS Satellite Database - download from https://www.ucs.org/resources/satellite-database
# Place CSV at vela/data/ucs_satellite_database.csv
UCS_DATABASE_PATH=data/ucs_satellite_database.csv
